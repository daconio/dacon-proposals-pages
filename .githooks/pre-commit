#!/usr/bin/env bash
# pre-commit hook — index.html 카드 그리드 자동 동기화
#
# 동작:
#   1. scripts/cards.json 에 미등록 HTML(scan 대상 디렉토리)이 있으면 자동 등록 (AUTO-REGISTER)
#   2. cards.json 기준으로 index.html 재생성
#   3. 변경된 cards.json · index.html을 자동으로 re-stage
#
# 설치:
#   git config core.hooksPath .githooks
#
# 우회:
#   SKIP_CARD_SYNC=1 git commit ...     # 자동 등록·sync 스킵
#   SKIP_AUTOREGISTER=1 git commit ...  # 자동 등록만 스킵 (sync는 실행)
#   git commit --no-verify ...          # 모든 훅 스킵

set -e

if [[ "${SKIP_CARD_SYNC:-}" == "1" ]]; then
  echo "[pre-commit] SKIP_CARD_SYNC=1 → skipping card sync"
  exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
SCRIPT="$REPO_ROOT/scripts/sync_cards.py"

if [[ ! -f "$SCRIPT" ]]; then
  echo "[pre-commit] scripts/sync_cards.py not found — skipping"
  exit 0
fi

if ! command -v python3 >/dev/null 2>&1; then
  echo "[pre-commit] python3 not available — skipping card sync"
  exit 0
fi

# 1. Auto-register any unregistered HTML under the scan directories.
#    --autoregister inserts sensible defaults into cards.json and then
#    re-syncs index.html in the same run.
if [[ "${SKIP_AUTOREGISTER:-}" == "1" ]]; then
  echo "[pre-commit] SKIP_AUTOREGISTER=1 → sync only, no auto-add"
  python3 "$SCRIPT"
else
  python3 "$SCRIPT" --autoregister
fi

# 2. Re-stage cards.json / index.html if they changed.
for f in "scripts/cards.json" "index.html"; do
  if ! git diff --quiet -- "$f" 2>/dev/null; then
    echo "[pre-commit] ✨ $f auto-updated → re-staging"
    git add "$f"
  fi
done

# 4. MD ↔ HTML sync check (강원대 제안서 등 페어)
SYNC_CHECK="$REPO_ROOT/scripts/check_md_html_sync.py"
if [[ -f "$SYNC_CHECK" ]]; then
  python3 "$SYNC_CHECK" --all --quiet || {
    echo ""
    echo "[pre-commit] ⚠️  MD↔HTML 동기화 이슈가 감지되었습니다 (위 메시지 참조)."
    echo "[pre-commit]    커밋은 진행되지만, 가능한 빨리 양쪽 파일을 정렬해주세요."
    echo "[pre-commit]    수동 검증: python3 scripts/check_md_html_sync.py --all"
    echo ""
  }
fi

exit 0
